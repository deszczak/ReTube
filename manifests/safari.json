{
  "manifest_version": 2,
  "name": "ReTube – YouTube Video Responses",
  "version": "1.0",
  "description": "Revive YouTube video responses",
  "permissions": [
    "storage",
    "https://www.youtube.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [{
    "matches": ["https://www.youtube.com/watch*"],
    "js": ["content.js"],
    "css": ["styles.css"]
  }],
  "icons": {
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "64": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}